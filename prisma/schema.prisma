generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  phone          String?
  role           UserRole  @default(CUSTOMER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  driver         Driver?
  deliveries     Delivery[] @relation("CustomerDeliveries")
  reviews        Review[]

  @@map("users")
}

enum UserRole {
  CUSTOMER
  DRIVER
  ADMIN
}

// ─── Driver (subscriber) ────────────────────────────────────

model Driver {
  id                 String    @id @default(cuid())
  userId             String    @unique
  displayName        String
  bio                String?   @db.Text
  photo              String?
  phone              String?
  vanInfo            String?
  licensePlate       String?
  serviceAreas       String[]
  maxPackageWeight   Float?
  stripeAccountId    String?   @unique
  stripeAccountReady Boolean   @default(false)
  subscriptionId     String?   @unique
  subscriptionStatus SubStatus @default(INACTIVE)
  verified           Boolean   @default(false)
  available          Boolean   @default(true)
  rating             Float     @default(0)
  totalDeliveries    Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
  reviews    Review[]

  @@map("drivers")
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

// ─── Deliveries ─────────────────────────────────────────────

model Delivery {
  id              String         @id @default(cuid())
  customerId      String
  driverId        String?
  title           String
  description     String?        @db.Text
  packageSize     PackageSize    @default(MEDIUM)
  packageWeight   Float?
  packageCount    Int            @default(1)
  pickupAddress   String
  pickupCity      String
  pickupState     String
  pickupZip       String
  pickupLat       Float?
  pickupLng       Float?
  pickupContact   String?
  pickupPhone     String?
  pickupNotes     String?
  dropoffAddress  String
  dropoffCity     String
  dropoffState    String
  dropoffZip      String
  dropoffLat      Float?
  dropoffLng      Float?
  dropoffContact  String?
  dropoffPhone    String?
  dropoffNotes    String?
  images          String[]
  price           Float
  distance        Float?
  status          DeliveryStatus @default(POSTED)
  pickupDate      DateTime?
  pickupTime      String?
  deliveryDate    DateTime?
  deliveryTime    String?
  latestDeliveryTime String?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  trackingNote    String?
  photo           String?
  // Payment fields
  paymentIntentId String?        @unique
  paymentStatus   PaymentStatus  @default(UNPAID)
  transferId      String?        @unique
  refundId        String?
  platformFee     Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customer User @relation("CustomerDeliveries", fields: [customerId], references: [id])
  driver   Driver?  @relation(fields: [driverId], references: [id])

  @@map("deliveries")
}

enum PackageSize {
  SMALL
  MEDIUM
  LARGE
  XL
  XXL
  PALLET
}

enum DeliveryStatus {
  POSTED
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  TRANSFERRED
  REFUNDED
  FAILED
}

// ─── Reviews ────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  userId     String
  driverId   String
  deliveryId String?
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([userId, driverId])
  @@map("reviews")
}
